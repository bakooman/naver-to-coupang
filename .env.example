# ── 마진 설정 ─────────────────────────────────────────
# 1.3 = 30% 마진 (원가 × 1.3 = 판매가)
MARGIN_RATE=1.3

# ── 쿠팡 OPEN API ─────────────────────────────────────
# https://api-gateway.coupang.com 에서 발급
COUPANG_ACCESS_KEY=your_access_key_here
COUPANG_SECRET_KEY=your_secret_key_here
COUPANG_VENDOR_ID=your_vendor_id_here

# ── 네이버 크롤링 Residential Proxy ──────────────────────
# Smartproxy / Oxylabs / Bright Data 등에서 발급한 게이트웨이 URL
# 형식: http://user:pass@gate.smartproxy.com:10000
# 미설정 시 직접 연결 (Akamai WAF 차단 가능성 있음)
RESIDENTIAL_PROXY_URL=

# ── VPS SOCKS5 프록시 (쿠팡 API 전용) ─────────────────
# run.bat 이 SSH 터널을 자동으로 열어줌 (수동 변경 불필요)
VPS_HOST=1.201.123.110
VPS_SSH_KEY_PATH=ssh_keys/SSH_KeyPair-260527213658.pem
SOCKS5_PORT=1080
# true = 쿠팡 API 를 VPS 터널로 라우팅 (권장)
# false = 직접 연결 (테스트용)
USE_SOCKS5=true
